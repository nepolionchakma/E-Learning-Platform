        {
          "name": "Complete backup.sh Script",
          "type": "codeblock",
          "code": "#!/bin/bash\nsrc=\"$1\"\ndst=\"$2\"\ndate=$(date +%Y%m%d_%H%M%S)\narchive=\"backup_$date.tar.gz\"\n\nif [ -z \"$src\" ] || [ -z \"$dst\" ]; then\n    echo \"Usage: $0 <source> <dest>\"\n    exit 1\nfi\n\nif [ ! -d \"$src\" ]; then\n    echo \"Error: Source not found\"\n    exit 1\nfi\n\ntar -czf \"$dst/$archive\" \"$src\" 2>/dev/null\nif [ $? -eq 0 ]; then\n    echo \"Backup created: $dst/$archive\"\nelse\n    echo \"Backup failed\"\n    exit 1\nfi"
        }
